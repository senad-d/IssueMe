{
  "name": "@senad-d/issueme",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent-friendly GitHub issue management layer for Pi using GitHub APIs and local issue files.",
  "license": "MIT",
  "author": "Senad Dizdarević <112484166+senad-d@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/senad-d/IssueMe.git"
  },
  "bugs": {
    "url": "https://github.com/senad-d/IssueMe/issues"
  },
  "homepage": "https://github.com/senad-d/IssueMe#readme",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "github",
    "github-api",
    "github-issues",
    "issue-management",
    "issue-tracking",
    "agent-tools",
    "llm-tools",
    "ai-agent",
    "projects-v2",
    "sub-issues",
    "coding-agent",
    "typescript"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "docs/**/*.md",
    "skills/**/*.md",
    "src/**/*.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "pi --no-extensions -e .",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run format:check && npm run check",
    "format:check": "node scripts/check-format.mjs",
    "test": "node --test test/*.test.mjs",
    "test:tui-artifacts": "node scripts/generate-tui-artifacts.mjs",
    "smoke:discover": "node scripts/smoke-observability.mjs",
    "smoke:packaged": "node scripts/smoke-packaged-install.mjs",
    "smoke:handlers": "node scripts/smoke-handler-execution.mjs",
    "smoke:pi-lifecycle": "node scripts/smoke-pi-lifecycle.mjs",
    "check": "node --check scripts/check-package-contents.mjs && node --check scripts/smoke-observability.mjs && node --check scripts/smoke-packaged-install.mjs && node --check scripts/smoke-handler-execution.mjs && node --check scripts/smoke-pi-lifecycle.mjs",
    "pack:dry-run": "npm pack --dry-run --json",
    "check:pack": "node scripts/check-package-contents.mjs",
    "validate": "npm run lint && npm run test && npm run check:pack && npm run smoke:packaged && npm run smoke:handlers && npm run smoke:pi-lifecycle"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "image": "https://raw.githubusercontent.com/senad-d/IssueMe/main/img/demo.gif"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^26.0.1",
    "typebox": "^1.3.2",
    "typescript": "^6.0.3"
  }
}
