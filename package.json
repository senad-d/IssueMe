{
  "name": "@senad-d/issueme",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent-friendly GitHub issue management layer for Pi using GitHub REST API and local issue files.",
  "license": "MIT",
  "author": "Senad Dizdarević <112484166+senad-d@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/senad-d/issueme.git"
  },
  "bugs": {
    "url": "https://github.com/senad-d/issueme/issues"
  },
  "homepage": "https://github.com/senad-d/issueme#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "github",
    "github-issues",
    "issues",
    "agent-tools",
    "typescript",
    "coding-agent"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "docs/**/*.md",
    "src/commands/issueme-command.ts",
    "src/config/config.ts",
    "src/constants.ts",
    "src/errors.ts",
    "src/extension.ts",
    "src/github/client.ts",
    "src/github/repository.ts",
    "src/issues/format.ts",
    "src/issues/store.ts",
    "src/tools/assign-issue.ts",
    "src/tools/close-issue.ts",
    "src/tools/comment-issue.ts",
    "src/tools/create-issue.ts",
    "src/tools/get-issue.ts",
    "src/tools/issueme-tools.ts",
    "src/tools/label-issue.ts",
    "src/tools/runtime.ts",
    "src/tools/sync-issues.ts",
    "src/tools/update-issue.ts",
    "src/types.ts",
    "src/utils/env.ts",
    "src/utils/slug.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "pi --no-extensions -e .",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run check",
    "format:check": "node scripts/check-format.mjs",
    "test": "node --test test/*.test.mjs",
    "check": "node --check scripts/check-package-contents.mjs",
    "pack:dry-run": "npm pack --dry-run --json",
    "check:pack": "node scripts/check-package-contents.mjs",
    "validate": "npm run typecheck && npm run test && npm run check && npm run check:pack"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^25.9.3",
    "typebox": "^1.2.18",
    "typescript": "^6.0.3"
  }
}
