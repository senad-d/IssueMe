# IssueMe GitHub authentication
# Copy this file to .env in the project root, then replace the placeholder.
# Never commit real tokens or credentials.

# Required: set either GH_TOKEN or GITHUB_TOKEN with repository issue access.
GH_TOKEN=replace_with_github_personal_access_token
# GITHUB_TOKEN=replace_with_github_personal_access_token

# Optional: set only when local Git metadata cannot resolve the repository.
# GITHUB_REPOSITORY=owner/repo
